DATABASE_URL=postgresql://host:5432/trabalho_arretado
DATABASE_USER=postgres
DATABASE_PASSWORD=
JWT_SECRET=

# Object storage (S3-compatível). Em dev usamos S3 Ninja via docker-compose.
# UI web: http://localhost:9000  — o bucket `avatars` será criado pela API no boot.
# S3 Ninja aceita quaisquer credenciais; mantemos os valores AWS example.
#
# ATENÇÃO a dois pontos no setup com emulador Android:
# 1. S3_ENDPOINT é usado pelo BACKEND (roda na sua máquina) → usa `localhost`.
#    S3_PUBLIC_BASE_URL é a URL que o APP no emulador baixa → precisa de `10.0.2.2`
#    (no emulador, `localhost` é o próprio emulador, não a máquina host).
# 2. O bucket `avatars` nasce PRIVADO no S3 Ninja (GET sem assinatura = 403, o Coil
#    não consegue carregar). Torne-o público uma vez na UI: http://localhost:9000/ui
#    → bucket avatars → "make public" (ou GET http://localhost:9000/ui/avatars?make-public).
#    O estado fica salvo no volume s3_data.
S3_ENDPOINT=http://localhost:9000/s3
S3_REGION=us-east-1
S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET=avatars
S3_PUBLIC_BASE_URL=http://10.0.2.2:9000/s3/avatars
S3_PATH_STYLE=true
